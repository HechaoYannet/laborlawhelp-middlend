# LaborLawHelp Middlend Configuration
# ====================================

# Storage: memory (dev) or postgres (prod)
storage_backend=memory

# OpenHarness integration mode: mock / library / remote
oh_mode=library
oh_use_mock=false

# Library mode: DeepSeek
oh_lib_model=deepseek-chat
oh_lib_api_format=openai
oh_lib_base_url=https://api.deepseek.com/v1
oh_lib_api_key=sk-54e274fd754b41658ebdd8670039cd67
oh_lib_max_turns=10
oh_lib_tool_policy=legal_minimal

# DeepSeek max_tokens limit is 8192 (OH default 16384 is too high)
OPENHARNESS_MAX_TOKENS=8192

# PKULaw MCP (configured via OH env vars)
# Uses local patched pkulaw-mcp-router build (node-fetch + SSE→JSON fix)
PKULAW_MCP_CONFIG=/home/chen-hao/repositories/pkulaw-mcp-router/pkulaw-mcp-router/config.toml
PKULAW_MCP_TOKEN=12b8c56d-14c7-33ef-957a-cbb73bde2fda
PKULAW_MCP_COMMAND=node
PKULAW_MCP_ARGS=/home/chen-hao/repositories/pkulaw-mcp-router/pkulaw-mcp-router/dist/index.js serve --config /home/chen-hao/repositories/pkulaw-mcp-router/pkulaw-mcp-router/config.toml
PKULAW_MCP_ENABLED=true
PKULAW_MCP_SERVER_NAME=pkulaw

# Auth
auth_mode=anonymous
