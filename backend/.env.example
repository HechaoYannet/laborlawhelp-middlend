# app
app_name=LaborLawHelp Middlend
app_version=0.2.0

# storage
storage_backend=memory
database_url=postgresql://postgres:postgres@127.0.0.1:5432/laborlawhelp
redis_url=redis://127.0.0.1:6379/0
session_lock_timeout_seconds=30
rate_limit_per_minute=20
cors_allow_origins=http://localhost:5000
cors_allow_credentials=true
cors_allow_methods=*
cors_allow_headers=*

# auth
auth_mode=anonymous
jwt_secret_key=change-me
jwt_algorithm=HS256
jwt_access_token_expire_minutes=15
jwt_refresh_token_expire_days=7

# openharness (remote/mock)
oh_base_url=http://localhost:8080
oh_stream_path=/api/v1/stream-run
oh_api_key=sk-local
oh_default_workflow=labor_consultation
oh_use_mock=true
oh_mode=mock
oh_connect_timeout_sec=5
oh_read_timeout_sec=60
oh_first_chunk_timeout_sec=15
oh_retry_max_attempts=3
oh_retry_backoff_seconds=1,2,4
oh_protocol_error_threshold=20

# openharness (library mode, optional)
oh_lib_model=
oh_lib_api_format=openai
oh_lib_base_url=
oh_lib_api_key=
oh_lib_max_turns=20
oh_lib_cwd=
oh_lib_tool_policy=legal_minimal
OPENHARNESS_MAX_TOKENS=8192

# PKULaw MCP
PKULAW_MCP_CONFIG=/absolute/path/to/laborlawhelp-middlend/backend/pkulaw-config.toml
PKULAW_MCP_TOKEN=YOUR_PKULAW_TOKEN
PKULAW_MCP_COMMAND=node
PKULAW_MCP_ARGS=/absolute/path/to/pkulaw-mcp-router/pkulaw-mcp-router/dist/index.js serve --config /absolute/path/to/laborlawhelp-middlend/backend/pkulaw-config.toml

PKULAW_MCP_ENABLED=false
PKULAW_MCP_SERVER_NAME=pkulaw

# migration fallback
app_enable_local_rule_fallback=false
